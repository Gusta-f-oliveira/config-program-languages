{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Kotlin",
            "type": "shell",
            "command": "cmd",
            "args": [
                "/c",
                "mkdir \"${workspaceFolder}\\bin\" 2>nul & kotlinc \"${file}\" -include-runtime -d \"${workspaceFolder}\\bin\\${fileBasenameNoExtension}.jar\""
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "silent",
                "clear": true
            },
            "problemMatcher": []
        }
    ]
}