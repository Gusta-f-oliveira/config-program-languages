{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "compilar-freebasic",
            "type": "shell",
            "windows": {
                "command": "cmd",
                "args": [
                    "/c",
                    "if not exist \"${workspaceFolder}\\bin\" mkdir \"${workspaceFolder}\\bin\" && fbc -g -x \"${workspaceFolder}\\bin\\${fileBasenameNoExtension}.exe\" \"${file}\""
                ]
            },
            "linux": {
                "command": "bash",
                "args": [
                    "-c",
                    "mkdir -p /tmp/fbc_build && cp \"${file}\" /tmp/fbc_build/temp.bas && cd /tmp/fbc_build && fbc -g -x app temp.bas"
                ]
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": { "reveal": "silent" },
            "problemMatcher": []
        }
    ]
}