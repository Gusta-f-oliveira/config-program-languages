    "version": "0.2.0",
    "configurations": [
        {
            "name": "Swift: Debug (F5)",
            "type": "lldb",
            "request": "launch",
            "preLaunchTask": "swift-build",
            "console": "integratedTerminal",
            "sourceLanguages": [
                "swift"
            ],
            "windows": {
                "program": "${workspaceFolder}\\bin\\${fileBasenameNoExtension}.exe"
            },
            "linux": {
                "program": "/tmp/vscode_bin/${fileBasenameNoExtension}"
            }
        }
    ]
}