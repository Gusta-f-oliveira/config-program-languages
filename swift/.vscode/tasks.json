{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "swift-build",
            "type": "shell",
            "command": "cmd",
            "args": [
                "/C",
                "cd /d \"${workspaceFolder}\" && if not exist bin mkdir bin && if not exist temp mkdir temp && swiftc -g \"${file}\" -o \"bin\\${fileBasenameNoExtension}.exe\" && (if exist \"bin\\${fileBasenameNoExtension}.exp\" move /Y \"bin\\${fileBasenameNoExtension}.exp\" temp >nul) && (if exist \"bin\\${fileBasenameNoExtension}.lib\" move /Y \"bin\\${fileBasenameNoExtension}.lib\" temp >nul)"
            ],
            "group": "build",
            "problemMatcher": []
        }
    ]
}