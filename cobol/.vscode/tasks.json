{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Compilar COBOL",
            "type": "shell",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "windows": {
                "command": "cmd",
                "args": [
                    "/c",
                    "if not exist \"${workspaceFolder}\\bin\" mkdir \"${workspaceFolder}\\bin\" & if not exist \"${workspaceFolder}\\temp\" mkdir \"${workspaceFolder}\\temp\" & set COB_CONFIG_DIR=C:\\gnucobol\\config& cd /d \"${workspaceFolder}\\temp\" & cobc -x -g \"${file}\" -o \"${workspaceFolder}\\bin\\${fileBasenameNoExtension}.exe\""
                ]
            },
            "linux": {
                "command": "bash",
                "args": [
                    "-c",
                    "mkdir -p /tmp/vscode_bin && cp \"${file}\" /tmp/vscode_bin/\"${fileBasename}\" && cd /tmp/vscode_bin && cobc -x -free -g \"${fileBasename}\" -o \"${fileBasenameNoExtension}\""
                ]
            },
            "problemMatcher": []
        }
    ]
}