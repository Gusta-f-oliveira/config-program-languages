{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Simula",
            "type": "shell",
            "linux": {
                "command": "bash",
                "args": [
                    "-c",
                    "mkdir -p /tmp/simula_build && cp \"${file}\" /tmp/simula_build/temp.sim && cd /tmp/simula_build && cim temp.sim"
                ]
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "clear": true
            }
        }
    ]
}