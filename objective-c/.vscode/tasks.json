{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build-objc",
            "type": "shell",
            "command": "cmd",
            "args": [
                "/c",
                "mkdir \"${workspaceFolder}\\bin\" 2>nul & gcc -g -x objective-c \"${file}\" -o \"${workspaceFolder}\\bin\\${fileBasenameNoExtension}.exe\" -lobjc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "clear": true
            },
            "problemMatcher": "$gcc"
        }
    ]
}