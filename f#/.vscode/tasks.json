{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build F# Universal",
            "type": "shell",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "windows": {
                "command": "dotnet",
                "args": [
                    "build",
                    "${fileDirname}",
                    "-o",
                    "${fileDirname}/build_output",
                    "/p:AssemblyName=app",
                    "/property:GenerateFullPaths=true",
                    "/consoleloggerparameters:NoSummary"
                ]
            },
            "linux": {
                "command": "dotnet",
                "args": [
                    "build",
                    "${fileDirname}",
                    "-o",
                    "/tmp/vscode_bin/fsharp_build/${fileBasenameNoExtension}/bin",
                    "/p:BaseIntermediateOutputPath=/tmp/vscode_bin/fsharp_build/${fileBasenameNoExtension}/obj/",
                    "/p:AssemblyName=app",
                    "/property:GenerateFullPaths=true",
                    "/consoleloggerparameters:NoSummary"
                ]
            },
            "problemMatcher": "$msCompile"
        }
    ]
}