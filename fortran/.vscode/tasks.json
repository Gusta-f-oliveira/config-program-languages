{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "type": "shell",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "windows": {
                "command": "cmd",
                "args": [
                    "/c",
                    "if not exist \"${workspaceFolder}\\bin\" mkdir \"${workspaceFolder}\\bin\" & if not exist \"${workspaceFolder}\\temp\" mkdir \"${workspaceFolder}\\temp\" & gfortran -static -g \"${file}\" -J \"${workspaceFolder}\\temp\" -o \"${workspaceFolder}\\bin\\${fileBasenameNoExtension}.exe\""
                ]
            },
            "linux": {
                "command": "bash",
                "args": [
                    "-c",
                    "mkdir -p /tmp/vscode_bin && gfortran -static -g \"${file}\" -J /tmp/vscode_bin -o /tmp/vscode_bin/\"${fileBasenameNoExtension}\""
                ]
            },
            "presentation": {
                "echo": false,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": false,
                "clear": true
            },
            "problemMatcher": "$gcc"
        }
    ]
}