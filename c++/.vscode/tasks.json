{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build-cpp",
            "type": "shell",
            "command": "cmd",
            "args": [
                "/c",
                "mkdir \"${workspaceFolder}\\bin\" 2>nul & g++ -g \"${file}\" -o \"${workspaceFolder}\\bin\\${fileBasenameNoExtension}.exe\""
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "silent",
                "clear": true
            },
            "problemMatcher": "$gcc"
        }
    ]
}